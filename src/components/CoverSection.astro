---
---

<section id="cover-section" class="relative min-h-screen bg-surface text-on-surface flex items-center justify-center overflow-hidden px-margin-mobile paper-texture">
	<lottie-player id="cover-lottie" class="absolute inset-0 z-0 pointer-events-none opacity-0 transition-opacity duration-700 ease-out" src="https://assets3.lottiefiles.com/packages/lf20_UJNc2t.json" renderer="svg" mode="normal" background="transparent" speed="1" loop="false"></lottie-player>
	<div class="absolute inset-0 bg-gradient-to-b from-surface/95 via-surface/95 to-surface-container-low/95"></div>
	<div class="absolute top-8 left-8 opacity-30">
		<span class="material-symbols-outlined text-secondary text-4xl" style="font-variation-settings: 'wght' 100;">filter_vintage</span>
	</div>
	<div class="absolute top-8 right-8 opacity-30 rotate-90">
		<span class="material-symbols-outlined text-secondary text-4xl" style="font-variation-settings: 'wght' 100;">filter_vintage</span>
	</div>
	<div class="relative z-10 w-full max-w-lg py-stack-lg double-border cover-card">
		<div class="rounded-[32px] border border-outline-variant/30 bg-surface-container-low p-stack-lg shadow-[0_20px_80px_rgba(0,0,0,0.08)]">
			<div class="flex flex-col items-center text-center gap-stack-lg">
				<div class="flex flex-col items-center gap-stack-sm">
					<div class="relative flex h-24 w-24 items-center justify-center rounded-full border border-secondary/30">
						<div class="absolute inset-0 rounded-full border border-secondary/10 scale-[1.05]"></div>
						<span class="font-display-lg text-primary text-5xl tracking-tight italic">C<span class="text-secondary text-3xl mx-1">&amp;</span>J</span>
					</div>
					<div class="h-12 w-px bg-gradient-to-b from-primary/50 to-transparent"></div>
				</div>
				<div class="space-y-stack-sm">
					<p class="font-label-caps text-label-caps text-secondary uppercase tracking-[0.3em]">The Wedding of</p>
					<h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary">Claudia &amp; Jacopo</h1>
					<div class="flex items-center justify-center gap-gutter pt-stack-sm">
						<div class="h-px w-12 bg-secondary/40"></div>
						<p class="font-body-lg text-body-lg text-on-surface-variant italic">25 Giugno 2025</p>
						<div class="h-px w-12 bg-secondary/40"></div>
					</div>
					<div class="pt-stack-md flex items-center justify-center gap-2 text-on-surface-variant">
						<span class="material-symbols-outlined text-sm">location_on</span>
						<p class="font-label-caps text-label-caps uppercase tracking-widest">Venezia, Italia</p>
					</div>
				</div>
				<button id="cover-enter" type="button" class="btn-primary btn-glow rounded-full px-10 py-4 mt-stack-lg">Apri l'invito</button>
				<p class="font-body-md text-body-lg text-on-surface-variant italic mt-stack-md">La vostra presenza è il nostro regalo più bello</p>
			</div>
		</div>
	</div>
</section>
