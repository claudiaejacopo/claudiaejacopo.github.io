---
import MusicToggle from './MusicToggle.astro';
---

<header class="sticky top-0 z-50 bg-surface border-b border-outline-variant/20 px-margin-mobile md:px-margin-desktop py-stack-md transition-all duration-300">
	<div class="max-w-container-max mx-auto flex items-center justify-between">
		<div class="flex items-center gap-stack-md">
			<span class="material-symbols-outlined text-primary" style="font-size: 28px;">favorite</span>
			<h1 class="font-headline-md text-headline-md text-primary">Claudia & Jacopo</h1>
		</div>
		<button id="menu-button" type="button" aria-expanded="false" aria-controls="anchor-nav" class="btn-secondary md:hidden">
			<span class="material-symbols-outlined">menu</span>
		</button>
	</div>

	<nav id="anchor-nav" class="hidden md:block md:mt-0" hidden>
		<ul class="flex flex-col md:flex-row gap-stack-md md:gap-stack-lg">
			<li><a href="#hero" class="font-body-md text-body-md text-on-surface hover:text-primary transition-colors">Hero</a></li>
			<li><a href="#programma" class="font-body-md text-body-md text-on-surface hover:text-primary transition-colors">Programma</a></li>
			<li><a href="#come-arrivare" class="font-body-md text-body-md text-on-surface hover:text-primary transition-colors">Come arrivare</a></li>
			<li><a href="/rsvp" class="font-body-md text-body-md text-on-surface hover:text-primary transition-colors">RSVP</a></li>
			<li><a href="/regalo" class="font-body-md text-body-md text-on-surface hover:text-primary transition-colors">Regalo</a></li>
		</ul>
	</nav>

	<MusicToggle />
</header>
