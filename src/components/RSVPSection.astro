<section id="rsvp" class="section rsvp-section">
	<div class="section-content">
		<h2>RSVP</h2>
		<p>Conferma la tua presenza e i dettagli del gruppo.</p>
		<form>
			<label>
				Nome
				<input type="text" name="name" placeholder="Il tuo nome" />
			</label>
			<label>
				Quante persone
				<input type="number" name="guests" min="1" />
			</label>
			<button type="submit">Invia</button>
		</form>
	</div>
</section>

<style>
	.rsvp-section form {
		display: grid;
		gap: 12px;
	}

	.rsvp-section input {
		width: 100%;
		padding: 0.85rem;
		border: 1px solid;
		border-radius: 12px;
	}

	.rsvp-section button {
		padding: 0.95rem 1.25rem;
		border: none;
		border-radius: 999px;
		cursor: pointer;
	}
</style>
