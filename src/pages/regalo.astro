---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section id="regalo" class="page-section regalo-page">
		<h1>Regalo / Lista nozze</h1>
		<p>Qui puoi inserire le informazioni sulla lista nozze, il conto regalo o il link al sito della lista.</p>
		<section>
			<h2>Come contribuire</h2>
			<ul>
				<li>Bonifico bancario</li>
				<li>Link al sito lista nozze</li>
				<li>Dettagli contatto per informazioni</li>
			</ul>
		</section>
		<p><a href="/">Torna alla home</a></p>
	</section>

	<style>
		.page-section {
			padding: 24px;
			max-width: 640px;
			margin: 0 auto;
		}

		h1 {
			font-size: 1.75rem;
			margin-bottom: 1rem;
		}

		h2 {
			font-size: 1.25rem;
			margin-top: 1.5rem;
		}

		ul {
			padding-left: 1.25rem;
		}

		a {
			color: inherit;
			text-decoration: underline;
		}
	</style>
