---
import Layout from '../layouts/Layout.astro';
import HeaderMobile from '../components/HeaderMobile.astro';
---

<Layout title="RSVP - Claudia & Jacopo | 25 Giugno 2025">
	<HeaderMobile />
	<section class="min-h-screen bg-surface text-on-surface">
		<main class="pt-24 px-margin-mobile py-stack-lg paper-texture">
			<div class="max-w-2xl mx-auto space-y-stack-lg">
				<div class="text-center space-y-stack-md">
					<span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">edit_calendar</span>
					<h2 class="font-display-lg-mobile text-display-lg-mobile text-primary">Conferma la Presenza</h2>
					<div class="h-px w-24 bg-outline-variant mx-auto"></div>
					<p class="font-body-lg text-body-lg text-on-surface-variant max-w-prose mx-auto italic">
						Se sei dei nostri, conferma la tua presenza e aiutaci a rendere il giorno del nostro matrimonio indimenticabile.
					</p>
				</div>

				<div class="rounded-[32px] bg-surface-container-low border border-outline-variant/20 p-stack-lg shadow-[0_20px_80px_rgba(155,63,37,0.08)]">
					<form id="rsvp-form" class="space-y-stack-lg">

						<div class="space-y-stack-sm">
							<p class="font-label-caps text-label-caps text-secondary uppercase tracking-[0.3em] mb-stack-sm">La tua risposta</p>
							<div class="grid grid-cols-1 gap-4">
								<label class="peer flex items-center justify-between rounded-full border border-outline-variant/20 bg-surface-container-highest px-4 py-4 cursor-pointer transition-all hover:border-primary peer-checked:border-primary peer-checked:bg-primary peer-checked:text-on-primary">
									<div class="flex items-center gap-3">
										<span class="material-symbols-outlined">favorite</span>
										<span class="font-body-md text-body-md">Ci sarò</span>
									</div>
									<input type="radio" name="partecipazione" value="Partecipo" class="hidden peer" required />
								</label>
								<label class="peer flex items-center justify-between rounded-full border border-outline-variant/20 bg-surface-container-highest px-4 py-4 cursor-pointer transition-all hover:border-primary peer-checked:border-primary peer-checked:bg-primary peer-checked:text-on-primary">
									<div class="flex items-center gap-3">
										<span class="material-symbols-outlined">event_busy</span>
										<span class="font-body-md text-body-md">Purtroppo no</span>
									</div>
									<input type="radio" name="partecipazione" value="Non partecipo" class="hidden peer" required />
								</label>
							</div>
						</div>

						<div class="space-y-stack-sm">
							<label for="note" class="block font-label-caps text-label-caps text-on-surface mb-stack-sm">Intolleranze alimentari o note speciali</label>
							<textarea id="note" name="note" rows="4" placeholder="Raccontaci se hai esigenze particolari o canzoni che vorresti sentire..." class="input-field w-full resize-none rounded-[24px] border border-outline-variant/20 bg-surface-container-highest px-4 py-4"></textarea>
						</div>

						<button type="submit" class="w-full rounded-full bg-primary px-6 py-4 text-on-primary font-label-caps text-label-caps hover:opacity-90 transition-all">INVIA CONFERMA</button>
					</form>
				</div>

				<div class="text-center pt-stack-lg">
					<a href="/" class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-on-primary font-label-caps text-label-caps shadow-sm hover:opacity-90 transition-all">Torna alla homepage</a>
				</div>
			</div>
		</main>
	</section>
</Layout>
